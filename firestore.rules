rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isAdmin() {
      // Check if user has admin record or is owner
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['owner', 'admin'];
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['telegramId', 'role', 'username', 'balance', 'createdAt']) &&
               data.telegramId is string && data.telegramId.size() <= 64 &&
               data.role in ['owner', 'admin', 'seller', 'guard', 'vip', 'member'] &&
               data.username is string && data.username.size() <= 64 &&
               data.balance is number && data.balance >= 0 &&
               data.createdAt is string &&
               (!data.keys().contains('expiryDate') || (data.expiryDate is string || data.expiryDate == null)) &&
               (!data.keys().contains('isBanned') || data.isBanned is bool);
      }

      // Users can read their own profile, admins can read all
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      
      // Only admins or system (via admin SDK) can create/update roles
      allow create: if isAdmin() && isValidUser(incoming());
      
      allow update: if isAdmin() && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['role', 'balance', 'username', 'expiryDate', 'isBanned'])
      );
    }

    // --- Groups Collection ---
    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Logs Collection ---
    match /logs/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // --- Polls Collection ---
    match /polls/{pollId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
    }

    // --- Blacklist Collection ---
    match /blacklist/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Transactions Collection ---
    match /transactions/{txId} {
      allow read: if isSignedIn() && (resource.data.sellerId == request.auth.uid || resource.data.buyerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().sellerId == request.auth.uid;
    }
  }
}
